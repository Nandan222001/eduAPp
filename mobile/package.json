{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev": "eas build --profile development --platform all",
    "build:dev:all": "eas build --profile development --platform all",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview": "eas build --profile preview --platform all",
    "build:preview:all": "eas build --profile preview --platform all",
    "build:staging:ios": "eas build --profile staging --platform ios",
    "build:staging:android": "eas build --profile staging --platform android",
    "build:staging": "eas build --profile staging --platform all",
    "build:prod:ios": "eas build --profile production-ios --platform ios",
    "build:prod:android": "eas build --profile production-android --platform android",
    "build:prod": "eas build --profile production --platform all",
    "build:prod:all": "eas build --profile production --platform all",
    "submit:preview:ios": "eas submit --profile preview --platform ios",
    "submit:preview:android": "eas submit --profile preview --platform android",
    "submit:staging:ios": "eas submit --profile staging --platform ios",
    "submit:staging:android": "eas submit --profile staging --platform android",
    "submit:prod:ios": "eas submit --profile production --platform ios",
    "submit:prod:android": "eas submit --profile production --platform android",
    "submit:prod:android:rollout": "eas submit --profile production-full --platform android",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:beta:ios": "eas submit --platform ios --profile beta",
    "submit:beta:android": "eas submit --platform android --profile beta",
    "submit:alpha:android": "eas submit --platform android --profile alpha",
    "update:development": "eas update --branch development --message",
    "update:preview": "eas update --branch preview --message",
    "update:staging": "eas update --branch staging --message",
    "update:production": "eas update --branch production --message",
    "update:publish:dev": "eas update --channel development --message",
    "update:publish:preview": "eas update --channel preview --message",
    "update:publish:staging": "eas update --channel staging --message",
    "update:publish:prod": "eas update --channel production --message",
    "channel:list": "eas channel:list",
    "channel:create": "eas channel:create",
    "channel:view": "eas channel:view",
    "build:list": "eas build:list",
    "build:view": "eas build:view",
    "build:cancel": "eas build:cancel",
    "credentials:ios": "eas credentials -p ios",
    "credentials:android": "eas credentials -p android",
    "metadata:pull": "eas metadata:pull",
    "metadata:push": "eas metadata:push",
    "version:bump:patch": "node scripts/version-bump.js patch",
    "version:bump:minor": "node scripts/version-bump.js minor",
    "version:bump:major": "node scripts/version-bump.js major",
    "deploy:preview": "npm run build:preview:all && npm run update:preview",
    "deploy:production": "npm run build:prod:all && npm run update:production",
    "release:ios": "node scripts/release-ios.js",
    "release:android": "node scripts/release-android.js",
    "release:full": "node scripts/release-full.js",
    "validate:deployment": "node scripts/validate-deployment.js",
    "pre-build": "node scripts/pre-build.js",
    "post-build": "node scripts/post-build.js",
    "check:updates": "node scripts/check-updates.js",
    "setup:credentials": "bash scripts/setup-credentials.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:components": "jest --testPathPattern=__tests__/components",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test": "detox test",
    "test:all": "npm run test:ci && npm run e2e:test",
    "test:e2e": "detox test",
    "test:e2e:build:ios": "detox build --configuration ios.debug",
    "test:e2e:build:android": "detox build --configuration android.debug",
    "test:e2e:ios": "detox test --configuration ios.debug",
    "test:e2e:android": "detox test --configuration android.debug"
  },
  "dependencies": {
    "@amplitude/analytics-react-native": "^1.3.1",
    "@gorhom/bottom-sheet": "^4.6.1",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/datetimepicker": "^7.6.2",
    "@react-native-community/netinfo": "^11.1.0",
    "@react-native-firebase/analytics": "^18.7.3",
    "@react-native-firebase/app": "^18.7.3",
    "@react-native-firebase/crashlytics": "^18.7.3",
    "@react-native-firebase/messaging": "^18.7.3",
    "@react-native-firebase/perf": "^18.7.3",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/drawer": "^6.6.6",
    "@react-navigation/material-top-tabs": "^7.4.19",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.18",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "@rneui/base": "^4.0.0-rc.8",
    "@rneui/themed": "^4.0.0-rc.8",
    "@sentry/react-native": "^5.15.2",
    "@tanstack/react-query": "^5.17.19",
    "axios": "^1.6.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.3.1",
    "expo": "~50.0.0",
    "expo-application": "~5.8.3",
    "expo-av": "~13.10.6",
    "expo-background-fetch": "~12.0.1",
    "expo-barcode-scanner": "~12.9.0",
    "expo-build-properties": "~0.11.1",
    "expo-calendar": "~12.0.1",
    "expo-camera": "~14.1.3",
    "expo-constants": "~15.4.6",
    "expo-device": "~5.9.4",
    "expo-document-picker": "~11.10.1",
    "expo-file-system": "~16.0.9",
    "expo-image-manipulator": "~11.8.0",
    "expo-image-picker": "~14.7.1",
    "expo-linking": "~6.2.2",
    "expo-local-authentication": "~13.8.0",
    "expo-media-library": "~15.9.2",
    "expo-notifications": "~0.27.8",
    "expo-print": "~12.8.1",
    "expo-router": "~3.4.0",
    "expo-secure-store": "~12.8.1",
    "expo-sharing": "~12.0.1",
    "expo-speech": "~11.7.0",
    "expo-status-bar": "~1.11.1",
    "expo-task-manager": "~11.8.2",
    "expo-updates": "~0.24.12",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-calendars": "^1.1314.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-dotenv": "^3.4.10",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-pager-view": "6.2.3",
    "react-native-pdf": "^6.7.5",
    "react-native-reanimated": "~3.6.1",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "^15.15.3",
    "react-native-vector-icons": "^10.0.3",
    "react-native-webview": "13.6.4",
    "react-redux": "^9.0.4",
    "redux-persist": "^6.0.0",
    "sentry-expo": "~8.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "@types/react-redux": "^7.1.33",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-jest": "^29.7.0",
    "detox": "^20.14.8",
    "eslint": "^8.56.0",
    "eslint-config-expo": "^7.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "jest-expo": "^50.0.1",
    "msw": "^2.0.11",
    "prettier": "^3.2.4",
    "react-native-reanimated": "~3.6.1",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
