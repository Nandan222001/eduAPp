{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "description": "Development build with dev client for local testing",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true,
        "buildConfiguration": "Debug",
        "image": "latest",
        "autoIncrement": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "latest",
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "development",
        "SENTRY_ENVIRONMENT": "development"
      }
    },
    "preview": {
      "description": "Preview build for internal testing (TestFlight/Internal Testing)",
      "distribution": "internal",
      "channel": "staging",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "buildConfiguration": "Release",
        "image": "latest",
        "enterpriseProvisioning": "adhoc",
        "autoIncrement": true,
        "bundleIdentifier": "com.yourcompany.eduplatform"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest",
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "staging",
        "SENTRY_ENVIRONMENT": "staging"
      },
      "autoIncrement": true
    },
    "preview-internal": {
      "extends": "preview",
      "distribution": "internal",
      "channel": "preview-internal",
      "android": {
        "buildType": "apk"
      }
    },
    "staging": {
      "description": "Staging build for pre-production testing",
      "distribution": "internal",
      "channel": "staging",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "buildConfiguration": "Release",
        "image": "latest",
        "autoIncrement": true,
        "bundleIdentifier": "com.yourcompany.eduplatform.staging"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest",
        "autoIncrement": true,
        "applicationId": "com.yourcompany.eduplatform.staging"
      },
      "env": {
        "APP_ENV": "staging",
        "SENTRY_ENVIRONMENT": "staging"
      }
    },
    "production": {
      "description": "Production build for App Store and Google Play",
      "distribution": "store",
      "channel": "production",
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release",
        "image": "latest",
        "autoIncrement": "buildNumber",
        "bundleIdentifier": "com.yourcompany.eduplatform"
      },
      "android": {
        "buildType": "aab",
        "gradleCommand": ":app:bundleRelease",
        "image": "latest",
        "autoIncrement": "versionCode"
      },
      "env": {
        "APP_ENV": "production",
        "SENTRY_ENVIRONMENT": "production"
      },
      "autoIncrement": true
    },
    "production-ios": {
      "description": "Production iOS build for App Store",
      "extends": "production",
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release",
        "autoIncrement": "buildNumber",
        "bundleIdentifier": "com.yourcompany.eduplatform"
      }
    },
    "production-android": {
      "description": "Production Android build for Google Play",
      "extends": "production",
      "android": {
        "buildType": "aab",
        "gradleCommand": ":app:bundleRelease",
        "autoIncrement": "versionCode"
      }
    },
    "production-android-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    }
  },
  "submit": {
    "development": {
      "description": "Development submission (not typically used)"
    },
    "preview": {
      "description": "Preview submission to TestFlight and Internal Testing",
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "sku": "eduplatform-ios",
        "language": "en-US",
        "companyName": "Your Company Name",
        "appName": "EduPlatform"
      },
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },
    "beta": {
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}"
      },
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "beta",
        "releaseStatus": "completed",
        "rollout": 0.1
      }
    },
    "alpha": {
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "alpha",
        "releaseStatus": "completed"
      }
    },
    "staging": {
      "description": "Staging submission to TestFlight and Internal Testing",
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID_STAGING}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "sku": "eduplatform-staging"
      },
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "production": {
      "description": "Production submission to App Store and Google Play",
      "ios": {
        "appleId": "${APPLE_ID}",
        "ascAppId": "${ASC_APP_ID}",
        "appleTeamId": "${APPLE_TEAM_ID}",
        "sku": "eduplatform",
        "language": "en-US",
        "companyName": "Your Company Name",
        "appName": "EduPlatform"
      },
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "production",
        "releaseStatus": "completed",
        "rolloutFraction": 0.1
      }
    },
    "production-full": {
      "description": "Production submission with full rollout",
      "extends": "production",
      "android": {
        "serviceAccountKeyPath": "${GOOGLE_SERVICE_ACCOUNT_KEY_PATH}",
        "track": "production",
        "releaseStatus": "completed",
        "rolloutFraction": 1.0
      }
    }
  },
  "update": {
    "development": {
      "description": "OTA updates for development channel",
      "channel": "development"
    },
    "preview": {
      "description": "OTA updates for preview channel",
      "channel": "preview"
    },
    "staging": {
      "description": "OTA updates for staging channel",
      "channel": "staging"
    },
    "production": {
      "description": "OTA updates for production channel",
      "channel": "production"
    }
  }
}
