# App Environment
APP_ENV=development
APP_VERSION=1.0.0
APP_NAME=EDU Mobile

# Expo
EXPO_PROJECT_ID=your-expo-project-id
EXPO_OWNER=your-expo-username

# API Configuration
API_URL=http://localhost:8000
API_TIMEOUT=30000

# iOS Build Configuration
IOS_BUILD_NUMBER=1

# Android Build Configuration
ANDROID_VERSION_CODE=1

# Sentry Configuration
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ORG=your-organization
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ENVIRONMENT=development

# Firebase Configuration
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Amplitude Configuration
AMPLITUDE_API_KEY=your-amplitude-api-key
ANALYTICS_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true

# Apple Configuration (DO NOT COMMIT ACTUAL VALUES)
APPLE_ID=your-apple-id@example.com
APPLE_TEAM_ID=your-team-id
ASC_APP_ID=your-asc-app-id
ASC_APP_ID_STAGING=your-staging-asc-app-id

# Google Play Configuration (DO NOT COMMIT ACTUAL VALUES)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json
GOOGLE_PACKAGE_NAME=com.edu.mobile

# Android
ANDROID_KEYSTORE_PASSWORD=your-keystore-password
ANDROID_KEY_ALIAS=your-key-alias
ANDROID_KEY_PASSWORD=your-key-password
