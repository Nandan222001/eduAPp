#!/bin/bash
#
# Pre-commit hook for validating Alembic migrations
# Install this hook by copying to .git/hooks/pre-commit
#
# To install:
#   chmod +x scripts/migration_test/pre-commit-migration-check
#   cp scripts/migration_test/pre-commit-migration-check .git/hooks/pre-commit
#
# To skip hook for a commit:
#   git commit --no-verify
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}================================${NC}"
echo -e "${BLUE}Pre-commit Migration Validation${NC}"
echo -e "${BLUE}================================${NC}"

# Check if there are any migration files in the commit
MIGRATION_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "alembic/versions/.*\.py$" || true)

if [ -z "$MIGRATION_FILES" ]; then
    echo -e "${GREEN}✓ No migration files in this commit${NC}"
    exit 0
fi

echo -e "${YELLOW}Found migration files to validate:${NC}"
echo "$MIGRATION_FILES" | sed 's/^/  - /'
echo ""

# Check if migration test database is set up
if [ ! -f ".env.test.migration" ]; then
    echo -e "${YELLOW}⚠ Migration test database not configured${NC}"
    echo -e "${YELLOW}  Run: ./scripts/migration_test/setup_test_db.sh${NC}"
    echo -e "${YELLOW}  Skipping migration validation...${NC}"
    exit 0
fi

# Function to validate migration file syntax
validate_migration_syntax() {
    local file=$1
    echo -e "${BLUE}Validating syntax: $file${NC}"
    
    # Check if file has required functions
    if ! grep -q "def upgrade()" "$file"; then
        echo -e "${RED}✗ Missing upgrade() function in $file${NC}"
        return 1
    fi
    
    if ! grep -q "def downgrade()" "$file"; then
        echo -e "${RED}✗ Missing downgrade() function in $file${NC}"
        return 1
    fi
    
    # Check if file has revision ID
    if ! grep -q "^revision = " "$file"; then
        echo -e "${RED}✗ Missing revision ID in $file${NC}"
        return 1
    fi
    
    # Check if file has down_revision
    if ! grep -q "^down_revision = " "$file"; then
        echo -e "${RED}✗ Missing down_revision in $file${NC}"
        return 1
    fi
    
    # Check Python syntax
    if ! python -m py_compile "$file" 2>/dev/null; then
        echo -e "${RED}✗ Python syntax error in $file${NC}"
        return 1
    fi
    
    echo -e "${GREEN}✓ Syntax valid for $file${NC}"
    return 0
}

# Validate each migration file
VALIDATION_FAILED=0
for file in $MIGRATION_FILES; do
    if ! validate_migration_syntax "$file"; then
        VALIDATION_FAILED=1
    fi
done

if [ $VALIDATION_FAILED -eq 1 ]; then
    echo -e "${RED}================================${NC}"
    echo -e "${RED}Migration validation failed${NC}"
    echo -e "${RED}================================${NC}"
    exit 1
fi

# Check for duplicate revision IDs
echo -e "${BLUE}Checking for duplicate revision IDs...${NC}"
REVISION_IDS=$(grep -h "^revision = " alembic/versions/*.py | sort)
DUPLICATE_IDS=$(echo "$REVISION_IDS" | uniq -d)

if [ -n "$DUPLICATE_IDS" ]; then
    echo -e "${RED}✗ Found duplicate revision IDs:${NC}"
    echo "$DUPLICATE_IDS"
    exit 1
fi
echo -e "${GREEN}✓ No duplicate revision IDs found${NC}"

# Optional: Run quick migration test if requested
if [ "$SKIP_MIGRATION_TEST" != "1" ]; then
    echo -e "${BLUE}Running quick migration validation...${NC}"
    
    # This is a quick check - full validation should be done in CI
    if command -v python &> /dev/null; then
        if python scripts/migration_test/validate_migrations.py --quick 2>/dev/null; then
            echo -e "${GREEN}✓ Quick migration validation passed${NC}"
        else
            echo -e "${YELLOW}⚠ Quick validation had warnings (continuing)${NC}"
            # Don't fail the commit on warnings
        fi
    fi
fi

echo -e "${GREEN}================================${NC}"
echo -e "${GREEN}Migration validation passed!${NC}"
echo -e "${GREEN}================================${NC}"
echo ""
echo -e "${BLUE}Note: Full migration testing will run in CI/CD${NC}"
echo -e "${BLUE}To skip this hook: git commit --no-verify${NC}"
echo ""

exit 0
