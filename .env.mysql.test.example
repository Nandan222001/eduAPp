# MySQL Test Database Configuration
# Copy this file to .env.mysql.test and update with your test database credentials

# MySQL Test Database Connection
MYSQL_TEST_DATABASE_URL=mysql+pymysql://root:test_password@localhost:3306/test_mysql_migration?charset=utf8mb4

# Or configure individual components
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=test_password
DATABASE_NAME=test_mysql_migration

# Test Configuration
# Uncomment to use specific settings
# MYSQL_TEST_TIMEOUT=300
# MYSQL_TEST_VERBOSE=true
